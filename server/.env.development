# Guardian development overrides
# Enable via: set NODE_ENV=development

GUARDIAN_SERVER_PORT=3847
GUARDIAN_SERVER_URL=http://localhost:3847

# More aggressive local/dev settings for high-load simulation
WS_ADMISSION_MAX_CONCURRENT=120
WS_ADMISSION_PER_SEC=240
WS_ADMISSION_MAX_QUEUE=800
WS_ADMISSION_MAX_PER_IP=20
WS_ADMISSION_RETRY_AFTER_SEC=2
WS_ADMISSION_QUEUE_TIMEOUT_MS=12000
WS_ADMISSION_LOOPBACK_BYPASS=1
