# Guardian runtime settings (base)
# Load order: .env -> .env.${NODE_ENV}

# Desktop app target URL
GUARDIAN_SERVER_PORT=3847
GUARDIAN_SERVER_URL=http://localhost:3847

# WebSocket admission control
WS_ADMISSION_MAX_CONCURRENT=100
WS_ADMISSION_PER_SEC=200
WS_ADMISSION_MAX_QUEUE=500
WS_ADMISSION_MAX_PER_IP=20
WS_ADMISSION_RETRY_AFTER_SEC=2
WS_ADMISSION_QUEUE_TIMEOUT_MS=10000

# 1 = bypass per-IP limit for loopback (127.0.0.1/::1), 0 = disable bypass
WS_ADMISSION_LOOPBACK_BYPASS=1
